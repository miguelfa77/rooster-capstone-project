# Copy to railway-restore.env (gitignored). Do not commit secrets.
#
# `pg_dump_for_railway.sh` and `railway_pg_restore.sh` both load this file by default
# (path override: RAILWAY_RESTORE_ENV=/path/to/some.env). Put DATABASE_URL or PG* here
# for whichever host each command should use (often: local creds to create rooster.dump,
# then switch to Railway DATABASE_URL to restore, or use two env files and RAILWAY_RESTORE_ENV).
#
# --- Create dump (writes rooster.dump or DUMP_FILE) -------------------------
#   bash scripts/pg_dump_for_railway.sh
#
# --- Restore to Railway ------------------------------------------------------
#   bash scripts/railway_pg_restore.sh test
#   bash scripts/railway_pg_restore.sh wipe   # empty target DB if a prior restore left objects (then restore again)
#   bash scripts/railway_pg_restore.sh
#
# --- Preferred (one paste) -------------------------------------------------
# In Railway → Postgres → Variables, copy DATABASE_URL if present, or build the web
# service reference, e.g. ${{Postgres.DATABASE_URL}} — paste the resolved URL here
# from the dashboard (Connect / Variables), not hand-typed pieces.
#
# If auth still fails: the password *inside* Postgres may not match POSTGRES_PASSWORD
# in the UI (first init only). Fix: Railway → regenerate DB password / reset, or
# wipe volume + redeploy so init runs again, then paste the new DATABASE_URL.
#
# DATABASE_URL=postgresql://postgres:CAegG5b2aB5b6163CG1E6c5BB12a12Cf@centerbeam.proxy.rlwy.net:59013/railway
#
# --- Alternative (discrete vars) -------------------------------------------
# Use these only if you do not use DATABASE_URL above.
#
PGHOST=centerbeam.proxy.rlwy.net
PGPORT=59013
PGUSER=postgres
PGDATABASE=railway
PGPASSWORD=CAegG5b2aB5b6163CG1E6c5BB12a12Cf
PGSSLMODE=disable

# Optional: one-line password file (ignored by git)
# PGPASSWORD_FILE=scripts/.pgpass_secret

DUMP_FILE=rooster.dump
