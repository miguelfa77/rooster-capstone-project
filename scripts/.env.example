# Copy to scripts/.env (gitignored). Full local → Railway sync:
#   bash scripts/sync_local_to_railway.sh
#
# User name: use `postgres@` in each URL, or set PGUSER=postgres in this file
# (the script defaults PGUSER to postgres for URLs that omit a user).
#
# Local database (pg_dump source) — must include core, analytics, etc.
LOCAL_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/rooster
#
# Railway Postgres (from dashboard → Variables)
RAILWAY_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@HOST:PORT/railway
#
# Optional: dump path relative to repo root (default rooster.dump)
# DUMP_FILE=rooster.dump
