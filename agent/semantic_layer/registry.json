  ],
  "essential_terms": [
    {"key": "rentabilidad", "terms": ["rentabilidad", "rendimiento", "yield"], "criticality": "essential"},
    {"key": "presupuesto", "terms": ["presupuesto", "budget"], "criticality": "essential"},
    {"key": "barrio", "terms": ["barrio", "barrios", "neighborhood"], "criticality": "flavour"},
    {"key": "inversion", "terms": ["inversión", "invertir", "investment"], "criticality": "essential"},
    {"key": "precio", "terms": ["precio", "price"], "criticality": "essential"},
    {"key": "habitaciones", "terms": ["habitaciones", "dormitorios", "rooms", "bedrooms"], "criticality": "essential"},
